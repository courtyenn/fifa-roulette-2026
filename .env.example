# Copy to .env.local for local dev (vercel dev), and set the same three
# values in your Vercel project's Environment Variables for production.

# The service account's email, e.g. roulette-writer@my-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# The service account private key from the downloaded JSON key file.
# Paste the whole key including the BEGIN/END lines, wrapped in double quotes.
# Keep the literal \n sequences — the function converts them back to newlines.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"

# The ID from the sheet URL: docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEET_ID=
